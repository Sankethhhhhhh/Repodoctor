# ======================================================
# RepoDoctor - .gitignore
# ======================================================

############################
# Python
############################
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

############################
# Virtual Environments
############################
.venv/
venv/
env/
ENV/

############################
# Python Tooling
############################
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/

############################
# Coverage
############################
.coverage
.coverage.*
coverage/
htmlcov/

############################
# Logs
############################
*.log
logs/
*.out

############################
# Environment Variables
############################
.env
.env.*

############################
# Secrets
############################
*.pem
*.key
*.crt
*.p12
*.pfx

############################
# Node.js
############################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

############################
# Vite
############################
.vite/
dist/

############################
# Build Artifacts
############################
build/
out/
release/
target/
docs/

############################
# TypeScript
############################
*.tsbuildinfo

############################
# Database
############################
*.db
*.sqlite
*.sqlite3

############################
# PostgreSQL Local Data
############################
postgres_data/

############################
# Redis Local Data
############################
redis_data/

############################
# Docker
############################
docker-compose.override.yml

############################
# IDE
############################
.vscode/
.idea/

############################
# OS Files
############################
.DS_Store
Thumbs.db
Desktop.ini

############################
# Temporary Files
############################
tmp/
temp/
*.tmp
*.bak
*.old
*.orig

############################
# Archives
############################
*.zip
*.tar
*.gz
*.rar
*.7z

backend/.venv/
backend/.env
backend/*.db
__pycache__/

############################
# Cache
############################
.cache/
.cache-loader/

############################
# Misc
############################
*.swp
*.swo
*.seed

############################
# Keep Empty Directories
############################
!.gitkeep